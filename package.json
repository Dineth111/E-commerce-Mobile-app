{
  "name": "fashion-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "fashion": "npm run start --workspace=e-commerce-mobile-app",
    "admin": "npm run start --workspace=admin-app",
    "dev": "turbo run start --parallel"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
